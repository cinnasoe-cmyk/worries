<%- include('partials/head') %>
<section class="dashHead">
  <div>
    <p class="eyebrow">dashboard</p>
    <h1>edit your worries page.</h1>
    <p>Your public page: <a href="/<%= currentUser.username %>" target="_blank"><%= baseUrl %>/<%= currentUser.username %></a></p>
  </div>
  <div class="badge"><%= currentUser.is_vip ? 'VIP' : 'FREE' %></div>
</section>
<% if (saved) { %><p class="success">saved.</p><% } %>
<% if (error) { %>
  <p class="error">
    <% if (error === 'discord_env_missing') { %>
      Discord is not set up yet. Add DISCORD_CLIENT_ID and DISCORD_CLIENT_SECRET in Render.
    <% } else if (error === 'discord_state') { %>
      Discord connection expired. Try connecting again.
    <% } else { %>
      Something failed. Check your settings and try again.
    <% } %>
  </p>
<% } %>
<section class="dashboardGrid">
  <form method="post" action="/dashboard/profile" class="panel form" enctype="multipart/form-data">
    <h2>profile</h2>
    <label>Display name<input name="display_name" value="<%= profile.display_name || '' %>" maxlength="60"></label>
    <label>Bio<textarea name="bio" maxlength="220"><%= profile.bio || '' %></textarea></label>

    <% const canUseDiscordPfp = Boolean(profile.discord_id && profile.discord_avatar_url); %>
    <% const activePfpSource = profile.pfp_source === 'discord' && canUseDiscordPfp ? 'discord' : 'upload'; %>
    <div class="pfpChoiceBox">
      <p class="fieldTitle">Profile picture source</p>
      <label class="pfpOption <%= activePfpSource === 'upload' ? 'active' : '' %>">
        <input type="radio" name="pfp_source" value="upload" <%= activePfpSource === 'upload' ? 'checked' : '' %>>
        <span>
          <strong>Upload my own</strong>
          <small>Use a profile picture from your PC.</small>
        </span>
      </label>
      <label class="pfpOption <%= activePfpSource === 'discord' ? 'active' : '' %> <%= canUseDiscordPfp ? '' : 'disabled' %>">
        <input type="radio" name="pfp_source" value="discord" <%= activePfpSource === 'discord' ? 'checked' : '' %> <%= canUseDiscordPfp ? '' : 'disabled' %>>
        <% if (canUseDiscordPfp) { %><img src="<%= profile.discord_avatar_url %>" alt="Discord profile picture"><% } else { %><span class="miniDiscordLock">!</span><% } %>
        <span>
          <strong>Use Discord profile picture</strong>
          <small><%= canUseDiscordPfp ? 'Uses your connected Discord avatar.' : 'Connect Discord first to unlock this option.' %></small>
        </span>
      </label>
    </div>

    <div class="uploadField">
      <label class="uploadButtonLabel">Profile picture upload
        <span class="uploadButton"><span class="clipIcon">📎</span> upload</span>
        <input type="file" name="pfp_file" accept="image/png,image/jpeg,image/webp,image/gif">
        <em class="fileName" data-file-name>No file selected</em>
      </label>
      <% if (profile.pfp_url) { %>
        <div class="currentUpload"><img src="<%= profile.pfp_url %>" alt="current profile picture"><span>uploaded profile picture saved</span><label class="check miniCheck"><input type="checkbox" name="clear_pfp"> remove</label></div>
      <% } %>
      <% if (activePfpSource === 'discord') { %><p class="tiny">Your public page is currently using your Discord avatar.</p><% } %>
    </div>

    <div class="discordConnectBox">
      <div class="discordLeft">
        <% if (profile.discord_avatar_url) { %>
          <img class="discordAvatar" src="<%= profile.discord_avatar_url %>" alt="Discord avatar">
        <% } else { %>
          <div class="discordAvatar empty">!</div>
        <% } %>
        <div>
          <strong><%= profile.discord_global_name || profile.discord_username || 'Discord account' %></strong>
          <p><%= profile.discord_id ? '@' + profile.discord_username : 'Connect your Discord to show it on your page.' %></p>
        </div>
      </div>
      <% if (profile.discord_id) { %>
        <button class="ghostButton smallBtn" type="submit" formaction="/dashboard/discord/disconnect" formmethod="post">disconnect</button>
      <% } else { %>
        <a class="secondary smallBtn" href="/auth/discord">connect discord</a>
      <% } %>
    </div>

    <details class="advancedBox">
      <summary>Advanced</summary>
      <div class="advancedContent">
        <div class="uploadField">
          <label class="uploadButtonLabel">Banner image upload
            <span class="uploadButton"><span class="clipIcon">📎</span> upload</span>
            <input type="file" name="banner_file" accept="image/png,image/jpeg,image/webp,image/gif">
            <em class="fileName" data-file-name>No file selected</em>
          </label>
          <% if (profile.banner_url) { %>
            <div class="currentUpload wide"><span style="background-image:url('<%= profile.banner_url %>')"></span><em>current banner saved</em><label class="check miniCheck"><input type="checkbox" name="clear_banner"> remove</label></div>
          <% } %>
        </div>

        <div class="row2 colorRows">
          <label class="colorField">Background
            <div class="colorPick"><input type="color" name="background_color" value="<%= profile.background_color || '#050505' %>"><span><%= profile.background_color || '#050505' %></span></div>
          </label>
          <label class="colorField">Text
            <div class="colorPick"><input type="color" name="text_color" value="<%= profile.text_color || '#ffffff' %>"><span><%= profile.text_color || '#ffffff' %></span></div>
          </label>
          <label class="colorField">Accent
            <div class="colorPick"><input type="color" name="accent_color" value="<%= profile.accent_color || '#ffffff' %>"><span><%= profile.accent_color || '#ffffff' %></span></div>
          </label>
        </div>

        <label>Button style
          <select name="button_style">
            <% ['glass','solid','outline'].forEach(s => { %>
              <option value="<%= s %>" <%= profile.button_style === s ? 'selected' : '' %>><%= s %></option>
            <% }) %>
          </select>
        </label>
        <label>VIP font
          <input name="font_family" value="<%= profile.font_family || 'Inter' %>" <%= currentUser.is_vip ? '' : 'disabled' %> placeholder="Inter, Arial, serif">
        </label>
        <div class="uploadField <%= currentUser.is_vip ? '' : 'lockedUpload' %>">
          <label class="uploadButtonLabel">VIP song upload <small>MP3 or WAV</small>
          <span class="uploadButton"><span class="clipIcon">📎</span> upload</span>
          <input type="file" name="music_file" accept="audio/mpeg,audio/mp3,audio/wav" <%= currentUser.is_vip ? '' : 'disabled' %>>
          <em class="fileName" data-file-name>No file selected</em>
        </label>
          <% if (profile.music_url && currentUser.is_vip) { %>
            <div class="currentUpload audioSaved"><span>♪</span><em>song saved and active</em><label class="check miniCheck"><input type="checkbox" name="clear_music"> remove</label></div>
          <% } else if (!currentUser.is_vip) { %>
            <p class="tiny">Upgrade to VIP to upload an MP3/WAV song for your page.</p>
          <% } %>
        </div>
        <label class="check"><input type="checkbox" name="show_views" <%= profile.show_views ? 'checked' : '' %>> show view count</label>
      </div>
    </details>

    <button class="primary full" type="submit">save profile</button>
  </form>

  <div class="panel">
    <h2>links</h2>
    <form method="post" action="/dashboard/links/add" class="form compact" enctype="multipart/form-data">
      <input name="title" placeholder="button title" required>
      <input name="url" placeholder="link URL" required>
      <label class="fileOnly uploadButtonLabel">Button icon upload
        <span class="uploadButton"><span class="clipIcon">📎</span> upload</span>
        <input type="file" name="icon_file" accept="image/png,image/jpeg,image/webp,image/gif">
        <em class="fileName" data-file-name>No file selected</em>
      </label>
      <button class="secondary full" type="submit">add link</button>
    </form>
    <div class="linkEditor">
      <% links.forEach(link => { %>
        <form class="linkEdit" method="post" action="/dashboard/links/<%= link.id %>/update" enctype="multipart/form-data">
          <input name="title" value="<%= link.title %>">
          <input name="url" value="<%= link.url %>">
          <label class="fileOnly uploadButtonLabel">Change icon
          <span class="uploadButton"><span class="clipIcon">📎</span> upload</span>
          <input type="file" name="icon_file" accept="image/png,image/jpeg,image/webp,image/gif">
          <em class="fileName" data-file-name>No file selected</em>
        </label>
          <% if (link.icon_url) { %><div class="currentUpload smallIcon"><img src="<%= link.icon_url %>" alt="current icon"><span>icon saved</span><label class="check miniCheck"><input type="checkbox" name="clear_icon"> remove</label></div><% } %>
          <input name="position" type="number" value="<%= link.position %>">
          <label class="check"><input name="is_visible" type="checkbox" <%= link.is_visible ? 'checked' : '' %>> visible</label>
          <button class="ghostButton" type="submit">save</button>
        </form>
        <form method="post" action="/dashboard/links/<%= link.id %>/delete"><button class="delete" type="submit">delete</button></form>
      <% }) %>
    </div>
  </div>
</section>
<%- include('partials/foot') %>

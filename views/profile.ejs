<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    body.publicPage { background: <%= profile.background_color %>; color: <%= profile.text_color %>; font-family: <%= profile.font_family || 'Inter' %>, Inter, Arial, sans-serif; }
    .publicCard { --accent: <%= profile.accent_color %>; }
  </style>
</head>
<body class="publicPage">
  <% const publicAvatarUrl = profile.pfp_source === 'discord' && profile.discord_avatar_url ? profile.discord_avatar_url : (profile.pfp_url || '/img/default-avatar.svg'); %>
  <% if (profile.music_url) { %>
    <audio id="pageAudio" loop preload="auto" src="<%= profile.music_url %>"></audio>
    <div class="volumeKnob" data-audio-control>
      <button type="button" data-music-toggle aria-label="play or pause page song">♪</button>
      <input type="range" min="0" max="100" value="45" data-volume-slider aria-label="page song volume">
      <span data-volume-label>45</span>
    </div>
  <% } %>
  <main class="publicWrap">
    <section class="publicCard">
      <% if (profile.banner_url) { %><div class="publicBanner" style="background-image:url('<%= profile.banner_url %>')"></div><% } %>
      <img class="publicAvatar" src="<%= publicAvatarUrl %>" onerror="this.src='/img/default-avatar.svg'" alt="profile picture">
      <h1><%= profile.display_name || user.username %></h1>
      <p class="publicUser">@<%= user.username %></p>
      <p class="publicBio"><%= profile.bio %></p>

      <% if (profile.discord_id) { %>
        <a class="connectedDiscordCard" href="https://discord.com/users/<%= profile.discord_id %>" target="_blank" rel="noopener noreferrer">
          <% if (profile.discord_avatar_url) { %>
            <img src="<%= profile.discord_avatar_url %>" alt="Discord avatar">
          <% } else { %>
            <span class="discordFallback">!</span>
          <% } %>
          <span>
            <strong><%= profile.discord_global_name || profile.discord_username %></strong>
            <small>connected discord</small>
          </span>
        </a>
      <% } %>

      <div class="publicLinks">
        <% links.forEach(link => { %>
          <a class="publicBtn <%= profile.button_style %>" href="<%= link.url %>" target="_blank" rel="noopener noreferrer">
            <% if (link.icon_url) { %><img src="<%= link.icon_url %>" alt=""><% } %>
            <span><%= link.title %></span>
          </a>
        <% }) %>
      </div>
      <% if (profile.show_views) { %><p class="views"><%= profile.view_count %> views</p><% } %>
      <a class="madeWith" href="/">made with worries</a>
    </section>
  </main>
  <script src="/js/app.js"></script>
</body>
</html>
